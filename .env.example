# Aplicação
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# PostgreSQL (usuários, RBAC, JWKS)
POSTGRES_URL=
POSTGRES_POOL_MAX=

# MongoDB (refresh tokens, denylist, auditoria)
MONGODB_URL=
MONGODB_DB=

# JWT / Chaves
# Par de chaves Ed25519 em PEM, base64 (gerar com: pnpm tsx scripts/generate-keys.ts)
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACTIVE_KID=
JWT_ISSUER=https://iam.example.com
JWT_AUDIENCE=iam-clients
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Segurança
SCRYPT_COST=32768
SCRYPT_BLOCK_SIZE=8
SCRYPT_PARALLELIZATION=1
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=60000

# Observabilidade
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=iam-platform
METRICS_ENABLED=true
