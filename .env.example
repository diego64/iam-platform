# Contrato de ambiente da aplicação.
# Copie para .env e preencha. NUNCA versione o .env preenchido.
#
# As variáveis sem default são obrigatórias: a ausência de qualquer uma derruba o
# processo no boot, antes de abrir socket (src/config/env.ts).

# development | test | production
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
# Teto do encerramento gracioso; estourou, o processo sai com código 1.
SHUTDOWN_TIMEOUT_MS=10000

# Prontidão (/health/ready)
# Janela do cache do resultado positivo; 0 desliga.
HEALTH_CACHE_MS=2000
# Teto por dependência. Precisa ser menor que o timeout da sonda do orquestrador.
HEALTH_TIMEOUT_MS=1000

# PostgreSQL: usuários, RBAC, JWKS
# OBRIGATÓRIA. Precisa começar com postgres:// ou postgresql://
POSTGRES_URL=
POSTGRES_POOL_MAX=10

# MongoDB: refresh tokens, denylist, auditoria
# OBRIGATÓRIA. Precisa começar com mongodb:// ou mongodb+srv://
MONGODB_URL=
MONGODB_DB=iam_sessions

# Chaves e JWT
# Par Ed25519 em PEM, base64. Gerar com: pnpm tsx scripts/generate-keys.ts
# Só entra por env/secret manager. Proibido .pem no repositório.
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACTIVE_KID=
JWT_ISSUER=https://iam.example.com
JWT_AUDIENCE=iam-clients
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Senhas
SCRYPT_COST=32768
SCRYPT_BLOCK_SIZE=8
SCRYPT_PARALLELIZATION=1

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=60000

# Observabilidade
# Ausente/vazia desliga o pipeline de traces. Em produção, aponte para rede interna.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=iam-platform
# Proporção de traces amostrada (0 a 1). 1 em desenvolvimento, 0.1 em produção.
OTEL_TRACES_SAMPLER_ARG=1
# Registra GET /metrics e sobe o exportador. false | 0 | no | off desligam.
METRICS_ENABLED=true
# Libera /metrics fora de rede interna. Manter false: o endpoint expõe topologia,
# nomes de rota e volume de tráfego.
METRICS_PUBLIC=false
# Commit da imagem, rótulo de iam_build_info. Injetado pelo CD como build arg;
# fora dele fica "desconhecido", que é mais honesto que um valor inventado.
GIT_COMMIT=desconhecido
