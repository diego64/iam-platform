{
  "name": "iam-platform",
  "version": "0.1.0",
  "description": "Provedor de Identidade (IAM/SSO) — emissão e validação de tokens para microsserviços",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "vite": "^6.4.3"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src tests scripts --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src tests scripts --no-error-on-unmatched-pattern --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir tests/unit",
    "test:watch": "vitest --dir tests/unit",
    "test:integration": "node --env-file-if-exists=infra/compose/.env ./node_modules/vitest/vitest.mjs run --dir tests/integration --no-file-parallelism",
    "test:contract": "vitest run --dir tests/contract",
    "test:e2e": "node --env-file-if-exists=infra/compose/.env ./node_modules/vitest/vitest.mjs run --dir tests/e2e",
    "test:coverage": "vitest run --coverage --no-file-parallelism",
    "test:load": "k6 run tests/performance/k6/login-flood.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "openapi:validate": "spectral lint openapi/openapi.yaml",
    "infra:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/compose/docker-compose.yml down",
    "docker:build": "docker build -f infra/docker/Dockerfile -t iam-platform:local .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env iam-platform:local",
    "infra:test:up": "docker compose -f infra/compose/docker-compose.test.yml --env-file infra/compose/.env up -d --wait",
    "infra:test:down": "docker compose -f infra/compose/docker-compose.test.yml --env-file infra/compose/.env down",
    "infra:monitoring": "docker compose -f infra/compose/docker-compose.monitoring.yml up -d",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "jose": "^6.2.3",
    "mongodb": "^6.10.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.14.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.17.0",
    "husky": "^9.1.0",
    "lint-staged": "^17.1.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.7"
  }
}
