{
  "name": "iam-platform",
  "version": "0.1.0",
  "description": "Provedor de Identidade (IAM/SSO) — emissão e validação de tokens para microsserviços",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src tests scripts --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src tests scripts --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir tests/unit",
    "test:watch": "vitest --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:contract": "vitest run --dir tests/contract",
    "test:e2e": "vitest run --dir tests/e2e",
    "test:mutation": "stryker run",
    "test:coverage": "vitest run --coverage",
    "test:load": "k6 run tests/performance/k6/login-flood.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "openapi:validate": "spectral lint openapi/openapi.yaml",
    "infra:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/compose/docker-compose.yml down",
    "infra:monitoring": "docker compose -f infra/compose/docker-compose.monitoring.yml up -d",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "jose": "^5.9.0",
    "mongodb": "^6.10.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.7.0",
    "@stryker-mutator/vitest-runner": "^8.7.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@stoplight/spectral-cli": "^6.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
